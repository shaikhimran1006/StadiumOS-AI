# ============================================================================
# StadiumOS AI - Environment Variables
# Copy this file to .env and fill in values
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
ENVIRONMENT=development
APP_NAME=StadiumOS AI
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=info
PORT=8080

# ----------------------------------------------------------------------------
# Google Cloud Platform
# ----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=stadiumos-ai-dev
GOOGLE_APPLICATION_CREDENTIALS=
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# ----------------------------------------------------------------------------
# Firebase / Firestore
# ----------------------------------------------------------------------------
FIRESTORE_PROJECT=stadiumos-ai-dev
FIRESTORE_EMULATOR_HOST=localhost:8180
FIRESTORE_DATABASE=(default)

# ----------------------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-random-64-character-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=stadiumos-ai-dev.firebaseapp.com
FIREBASE_PROJECT_ID=stadiumos-ai-dev

# ----------------------------------------------------------------------------
# Pub/Sub
# ----------------------------------------------------------------------------
PUBSUB_PROJECT_ID=stadiumos-ai-dev
PUBSUB_EMULATOR_HOST=localhost:8280
PUBSUB_TOPIC_GAME_EVENTS=game-events
PUBSUB_TOPIC_PLAYER_UPDATES=player-updates
PUBSUB_TOPIC_ANALYTICS=analytics-events
PUBSUB_SUBSCRIPTION_GAME_EVENTS=game-events-sub
PUBSUB_SUBSCRIPTION_PLAYER_UPDATES=player-updates-sub
PUBSUB_SUBSCRIPTION_ANALYTICS=analytics-events-sub

# ----------------------------------------------------------------------------
# BigQuery
# ----------------------------------------------------------------------------
BIGQUERY_PROJECT=stadiumos-ai-dev
BIGQUERY_DATASET=stadium_analytics
BIGQUERY_TABLE_GAME_STATS=game_stats
BIGQUERY_TABLE_PLAYER_STATS=player_stats
BIGQUERY_TABLE_USER_EVENTS=user_events
BIGQUERY_TABLE_PREDICTIONS=predictions

# ----------------------------------------------------------------------------
# Cloud Storage
# ----------------------------------------------------------------------------
STORAGE_BUCKET=stadiumos-ai-prod-assets
STORAGE_PROJECT=stadiumos-ai-dev
CDN_URL=

# ----------------------------------------------------------------------------
# Vertex AI
# ----------------------------------------------------------------------------
VERTEX_AI_PROJECT=stadiumos-ai-dev
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash-001
VERTEX_AI_MAX_TOKENS=8192
VERTEX_AI_TEMPERATURE=0.3
VERTEX_AI_TOP_P=0.95

# ----------------------------------------------------------------------------
# Google Maps
# ----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=

# ----------------------------------------------------------------------------
# Speech-to-Text / Text-to-Speech
# ----------------------------------------------------------------------------
SPEECH_SAMPLE_RATE=16000
SPEECH_LANGUAGE_CODE=en-US

# ----------------------------------------------------------------------------
# Cloud Translation
# ----------------------------------------------------------------------------
TRANSLATION_DEFAULT_TARGET=en

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
FEATURE_AI_PREDICTIONS=true
FEATURE_REAL_TIME_CHAT=true
FEATURE_VOICE_INPUT=true
FEATURE_MULTILINGUAL=true
